{
  "name": "@parimal/frontend-init",
  "version": "1.0.0",
  "description": "CLI to scaffold opinionated frontend architectures in existing Next.js projects.",
  "keywords": [
    "frontend",
    "cli",
    "nextjs",
    "architecture",
    "scaffold",
    "starter"
  ],
  "homepage": "https://github.com/parimal/frontend-init#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/parimal/frontend-init.git"
  },
  "bugs": {
    "url": "https://github.com/parimal/frontend-init/issues"
  },
  "author": "Parimal Sharma",
  "license": "MIT",
  "type": "module",
  "bin": {
    "frontend-init": "./dist/cli.js"
  },
  "files": [
