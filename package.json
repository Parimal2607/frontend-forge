  ],
  "scripts": {
    "build": "tsup && npm run copy-templates",
    "copy-templates": "cpy \"templates/**/*\" dist/templates"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "commander": "^12.0.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "cpy-cli": "^7.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0"
  }
}
