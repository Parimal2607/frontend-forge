{
  "name": "@prmvx/frontend-forge",
  "version": "0.1.2",
  "description": "A modern CLI to scaffold production-ready frontend architectures and starter modules for existing Next.js projects.",
  "keywords": [
    "cli",
    "nextjs",
    "react",
    "frontend",
    "starter",
    "boilerplate",
    "scaffold",
    "architecture",
    "template",
    "generator",
    "typescript",
    "developer-tools",
    "productivity",
    "app-router"
  ],
  "homepage": "https://github.com/Parimal2607/frontend-forge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Parimal2607/frontend-forge.git"
  },
  "bugs": {
    "url": "https://github.com/Parimal2607/frontend-forge/issues"
  },
  "author": {
    "name": "Parimal Sharma",
    "url": "https://github.com/Parimal2607"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "frontend-forge": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsup && npm run copy-templates",
    "copy-templates": "cpy \"templates/**/*\" dist/templates --dot",
    "dev": "tsup --watch",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "commander": "^12.0.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "cpy-cli": "^7.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
